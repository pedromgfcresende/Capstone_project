# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://xange:xange@localhost:5544/xange

# CORS origins for the Vite dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Path to the CRM CSV folder (the 3 Affinity lead exports) — used by the seed script
CRM_DATA_DIR=../../Capstone-Project_ESADE_x_XAnge/data

# ── LLM (Week 2) — provider-agnostic; fill in ONE key and set LLM_PROVIDER ──
LLM_PROVIDER=anthropic        # anthropic | openai
LLM_MODEL=                    # optional override (blank = provider default)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
