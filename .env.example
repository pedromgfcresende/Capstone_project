# Root env for `docker compose` (full stack). Copy to .env and fill what you need.
# Everything here is OPTIONAL — the app boots and serves with all of it blank;
# the AI/research/collector features just stay dormant until a key is present.

# ── LLM (synthesis, commentary, Q&A, enrichment) ──
LLM_PROVIDER=anthropic            # anthropic | openai
LLM_MODEL=                        # optional override (blank = provider default)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Web research (AI competitor discovery) ──
TAVILY_API_KEY=

# ── Open-data collectors ──
# All keyless EXCEPT UK Companies House (free key from developer.company-information.service.gov.uk)
COMPANIES_HOUSE_API_KEY=

# ── Seeding (optional) ──
# Absolute path INSIDE the container where the CRM CSVs are mounted (see compose comment).
CRM_DATA_DIR=/data
